# OpenClaw Agent 协作 UI - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# OpenClaw 连接配置
# ============================================

# OpenClaw Gateway Token
# 用于连接 OpenClaw Gateway，可从 ~/.openclaw/config.json 获取
OPENCLAW_TOKEN=your_gateway_token_here

# Gateway WebSocket URL
# 默认: ws://localhost:3101
OPENCLAW_WS_URL=ws://localhost:3101

# Gateway HTTP API URL
# 默认: http://localhost:3100
OPENCLAW_API_URL=http://localhost:3100

# ============================================
# Agent Session Keys
# ============================================

# 主 Agent Session Key（Timo）
# 格式: agent:main:feishu:direct:{open_id}
SESSION_KEY_MAIN=agent:main:feishu:direct:your_open_id_here

# 工程师 Agent Session Key
# 格式: agent:coder:feishu:direct:{open_id}
SESSION_KEY_CODER=agent:coder:feishu:direct:your_open_id_here

# 架构师 Agent Session Key
# 格式: agent:architect:feishu:direct:{open_id}
SESSION_KEY_ARCHITECT=agent:architect:feishu:direct:your_open_id_here

# 研究员 Agent Session Key
# 格式: agent:researcher:feishu:direct:{open_id}
SESSION_KEY_RESEARCHER=agent:researcher:feishu:direct:your_open_id_here

# ============================================
# 飞书集成配置（可选）
# ============================================

# 飞书应用 App ID
FEISHU_APP_ID=your_feishu_app_id

# 飞书应用 App Secret
FEISHU_APP_SECRET=your_feishu_app_secret

# 飞书验证 Token
FEISHU_VERIFICATION_TOKEN=your_verification_token

# 飞书加密密钥
FEISHU_ENCRYPT_KEY=your_encrypt_key

# ============================================
# UI 配置
# ============================================

# 默认主题 (light/dark)
DEFAULT_THEME=light

# 像素办公室 Canvas 尺寸
CANVAS_WIDTH=1000
CANVAS_HEIGHT=700

# 自动刷新间隔（毫秒）
REFRESH_INTERVAL=5000

# ============================================
# 开发配置
# ============================================

# 开发服务器端口
DEV_PORT=3000

# 是否启用调试模式
DEBUG=false

# API 基础路径
API_BASE_URL=http://localhost:3000/api